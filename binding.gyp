      'conditions': [
        ['OS=="mac"', {
          'defines': [
            'GIT_REGEX_REGCOMP',
            'GIT_USE_STAT_MTIMESPEC',
            'GIT_IO_POLL',
          ],
        }],
        ['OS=="linux" or OS.endswith("bsd")', {
          'cflags': [
            '-w',
          ],
          'defines': [
            'GIT_REGEX_REGCOMP',
            'GIT_USE_STAT_MTIM',
            'GIT_IO_POLL',
          ]
        }],
        ['OS=="win"', {
          'defines': [
            'GIT_WINHTTP',
            'GIT_IO_WSAPOLL',
            'GIT_REGEX_PCRE'
          ],
          'dependencies': [
            'pcre',
          ],
          'link_settings': {
            'libraries': [
              '-lcrypt32.lib',
              '-lrpcrt4.lib',
              '-lwinhttp.lib',
              '-lws2_32.lib',
            ],
          },
          'msvs_settings': {
            # Workaround of a strange bug:
            # TargetMachine + static_library + x64 = nothing.
            'conditions': [
              ['target_arch=="x64"', {
                'VCLibrarianTool': {
                  'AdditionalOptions': [
                    '/MACHINE:X64',
                  ],
                },
              }, {
                'VCLibrarianTool': {
                  'AdditionalOptions': [
                    '/MACHINE:x86',
                  ],
                },
              }],
            ],
          },
          'msvs_disabled_warnings': [
            4005,  # macro redefinition
            4244,  # conversion from 'ssize_t' to 'int32_t', possible loss of
                   # data
            4267,  # conversion from 'size_t' to 'int', possible loss of data
            4090,  # different 'volatile' qualifiers
            4047,  # 'volatile void *' differs in levels of indirection from
                   # 'int'
            4013,  # 'InterlockedDecrement' undefined; assuming extern
                   # returning int
          ],
          'sources': [
            'deps/libgit2/src/util/win32/dir.c',
            'deps/libgit2/src/util/win32/dir.h',
            'deps/libgit2/src/util/win32/error.c',
            'deps/libgit2/src/util/win32/error.h',
            'deps/libgit2/src/util/win32/map.c',
            'deps/libgit2/src/util/win32/mingw-compat.h',
            'deps/libgit2/src/util/win32/msvc-compat.h',
            'deps/libgit2/src/util/win32/path_w32.c',
            'deps/libgit2/src/util/win32/path_w32.h',
            'deps/libgit2/src/util/win32/posix.h',
            'deps/libgit2/src/util/win32/posix_w32.c',
            'deps/libgit2/src/util/win32/precompiled.c',
            'deps/libgit2/src/util/win32/precompiled.h',
            'deps/libgit2/src/util/win32/process.c',
            'deps/libgit2/src/util/win32/reparse.h',
            'deps/libgit2/src/util/win32/thread.c',
            'deps/libgit2/src/util/win32/thread.h',
            'deps/libgit2/src/util/win32/utf-conv.c',
            'deps/libgit2/src/util/win32/utf-conv.h',
            'deps/libgit2/src/util/win32/version.h',
            'deps/libgit2/src/util/win32/w32_buffer.c',
            'deps/libgit2/src/util/win32/w32_buffer.h',
            'deps/libgit2/src/util/win32/w32_common.h',
            'deps/libgit2/src/util/win32/w32_leakcheck.c',
            'deps/libgit2/src/util/win32/w32_leakcheck.h',
            'deps/libgit2/src/util/win32/w32_util.c',
            'deps/libgit2/src/util/win32/w32_util.h',
            'deps/libgit2/src/util/win32/win32-compat.h',
            'deps/libgit2/src/util/allocators/win32_leakcheck.c',
            'deps/libgit2/src/util/allocators/win32_leakcheck.h',
          ],
        }, {
          'libraries': [
            '-lpthread',
          ],
          'sources': [
            'deps/libgit2/src/util/unix/map.c',
            'deps/libgit2/src/util/unix/posix.h',
            'deps/libgit2/src/util/unix/pthread.h',
            'deps/libgit2/src/util/unix/process.c',
            'deps/libgit2/src/util/unix/realpath.c',
          ],
          'cflags': [
            '-Wno-missing-field-initializers',
            '-Wno-unused-variable',
            '-Wno-unused-function',
          ],
          'xcode_settings': {
            'WARNING_CFLAGS': [
              '-Wno-missing-field-initializers',
              '-Wno-unused-variable',
              '-Wno-unused-function',
            ],
          },
        }],
      ],
      'include_dirs': [
        'deps/libgit2/include',
        'deps/libgit2/src/libgit2',
        'deps/libgit2/src/util',
        'deps/libgit2/deps/xdiff',
        'deps/libgit2/deps/pcre',
        'deps/libgit2/deps/llhttp',
      ],
      'direct_dependent_settings': {
        'include_dirs': [
          'deps/libgit2/include',
        ],
      },
    },
    {
      'target_name': 'zlib',
      'win_delay_load_hook': 'false',
      'type': 'static_library',
      'sources': [
        'deps/libgit2/deps/zlib/adler32.c',
        'deps/libgit2/deps/zlib/crc32.c',
        'deps/libgit2/deps/zlib/crc32.h',
        'deps/libgit2/deps/zlib/deflate.c',
        'deps/libgit2/deps/zlib/deflate.h',
        'deps/libgit2/deps/zlib/gzguts.h',
        'deps/libgit2/deps/zlib/infback.c',
        'deps/libgit2/deps/zlib/inffast.c',
        'deps/libgit2/deps/zlib/inffast.h',
        'deps/libgit2/deps/zlib/inffixed.h',
        'deps/libgit2/deps/zlib/inflate.c',
        'deps/libgit2/deps/zlib/inflate.h',
        'deps/libgit2/deps/zlib/inftrees.c',
        'deps/libgit2/deps/zlib/inftrees.h',
        'deps/libgit2/deps/zlib/trees.c',
        'deps/libgit2/deps/zlib/trees.h',
        'deps/libgit2/deps/zlib/zconf.h',
        'deps/libgit2/deps/zlib/zlib.h',
        'deps/libgit2/deps/zlib/zutil.c',
        'deps/libgit2/deps/zlib/zutil.h',
      ],
      'defines': [
        'NO_VIZ',
        'STDC',
        'NO_GZIP',
        # zutil.h on macOS (TARGET_OS_MAC) defines fdopen(fd,mode)=NULL as a
        # Classic Mac OS / CodeWarrior compatibility shim, which breaks
        # stdio.h's real fdopen declaration when gzguts.h includes it.
        # Defining fdopen as an identity macro makes the #ifndef fdopen guard
        # in zutil.h skip the NULL redefinition.
        'fdopen=fdopen',
      ],
      'include_dirs': [
        'deps/libgit2/include',
      ],
      'direct_dependent_settings': {
        'include_dirs': [
          'deps/libgit2/deps/zlib',
        ],
      },
      'conditions': [
        ['OS=="win"', {
          'msvs_disabled_warnings': [
            4005,  # macro redefinition
          ],
          'include_dirs': [
            'deps/libgit2/deps/pcre',
          ],
        }],
      ],
    },
    {
      'target_name': 'llhttp',
      'win_delay_load_hook': 'false',
      'type': 'static_library',
      'sources': [
        'deps/libgit2/deps/llhttp/api.c',
        'deps/libgit2/deps/llhttp/http.c',
        'deps/libgit2/deps/llhttp/llhttp.c',
      ],
      'direct_dependent_settings': {
        'include_dirs': [
          'deps/libgit2/deps/llhttp',
        ],
      },
      'conditions': [
        ['OS=="win"', {
          'msvs_disabled_warnings': [
            4244,  # conversion from 'ssize_t' to 'int32_t', possible loss of
                   # data
          ],
        }],
      ],
    },
    {
      'target_name': 'xdiff',
      'win_delay_load_hook': 'false',
      'type': 'static_library',
      'defines': [
        # git2_util.h includes git2_features.h (cmake-generated) unless this
        # is defined. xdiff pulls in git2_util.h via regexp.h, so we need it.
        'LIBGIT2_NO_FEATURES_H',
      ],
      'conditions': [
        ['OS=="win"', {
          'defines': ['GIT_REGEX_PCRE'],
          'include_dirs': ['deps/libgit2/deps/pcre'],
        }, {
          'defines': ['GIT_REGEX_REGCOMP'],
        }],
      ],
      'include_dirs': [
        'deps/libgit2/include',
        'deps/libgit2/src/util',
        # regexp.h with GIT_REGEX_BUILTIN includes pcre.h from here.
        # 'deps/libgit2/deps/pcre',
      ],
      'sources': [
        'deps/libgit2/deps/xdiff/xdiffi.c',
        'deps/libgit2/deps/xdiff/xdiffi.h',
        'deps/libgit2/deps/xdiff/xemit.c',
        'deps/libgit2/deps/xdiff/xemit.h',
        'deps/libgit2/deps/xdiff/xhistogram.c',
        'deps/libgit2/deps/xdiff/xinclude.h',
        'deps/libgit2/deps/xdiff/xmacros.h',
        'deps/libgit2/deps/xdiff/xmerge.c',
        'deps/libgit2/deps/xdiff/xpatience.c',
        'deps/libgit2/deps/xdiff/xprepare.c',
        'deps/libgit2/deps/xdiff/xprepare.h',
        'deps/libgit2/deps/xdiff/xtypes.h',
        'deps/libgit2/deps/xdiff/xutils.c',
        'deps/libgit2/deps/xdiff/xutils.h',
        'deps/libgit2/deps/xdiff/xdiff.h',
      ],
      'direct_dependent_settings': {
        'include_dirs': [
          'deps/libgit2/deps/xdiff',
        ],
      },
    },
  ],
  'conditions': [
    ['OS=="win"', {
      'targets': [
          {
            'target_name': 'pcre',
            'win_delay_load_hook': 'false',
            'type': 'static_library',
            'sources': [
              'deps/libgit2/deps/pcre/pcre_byte_order.c',
