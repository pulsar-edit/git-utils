{
  'targets': [
    {
      'target_name': 'git',
      'dependencies': [
        'libgit2'
      ],
      'defines': [
        'NAPI_DISABLE_CPP_EXCEPTIONS',
      ],
      'include_dirs': [
        "<!(node -p \"require('node-addon-api').include_dir\")",
      ],
      'sources': [
        'src/binding.cc'
      ],
      'conditions': [
        ['OS=="win"', {
          'msvs_disabled_warnings': [
            4244,  # conversion from 'ssize_t' to 'int32_t', possible loss of
                   # data
            4530,  # C++ exception handler used, but unwind semantics are not
                   # enabled.
            4506,  # no definition for inline function
            4267,  # conversion from 'size_t' to 'int', possible loss of data
            4344,  # behavior change
          ],
        }, {
          'cflags': [
            '-Wno-missing-field-initializers',
          ],
          'cflags_cc!': [
            '-fno-delete-null-pointer-checks',  # clang-3.4 doesn't understand
                                                # this flag and fails.
          ],
          'xcode_settings': {
            'WARNING_CFLAGS': [
              '-Wno-missing-field-initializers',
            ],
          },
        }],
      ],
    },
    {
      'target_name': 'libgit2',
      'win_delay_load_hook': 'false',
      'type': 'static_library',
      'defines': [
        'GIT_THREADS',
        'LIBGIT2_NO_FEATURES_H',
        'GIT_SHA1_COLLISIONDETECT',
        'GIT_SHA256_BUILTIN',
        'GIT_HTTPPARSER_BUILTIN',
        # Node's util.h may be accidentally included so use this to guard
        # against compilation error.
        'SRC_UTIL_H_',
      ],
      'dependencies': [
        'zlib',
        'llhttp',
        'xdiff',
      ],
      'sources': [
        # src/libgit2 sources
        'deps/libgit2/src/libgit2/annotated_commit.c',
        'deps/libgit2/src/libgit2/annotated_commit.h',
        'deps/libgit2/src/libgit2/apply.c',
        'deps/libgit2/src/libgit2/apply.h',
        'deps/libgit2/src/libgit2/attr.c',
        'deps/libgit2/src/libgit2/attr.h',
        'deps/libgit2/src/libgit2/attr_file.c',
        'deps/libgit2/src/libgit2/attr_file.h',
        'deps/libgit2/src/libgit2/attrcache.c',
        'deps/libgit2/src/libgit2/attrcache.h',
        'deps/libgit2/src/libgit2/blame.c',
        'deps/libgit2/src/libgit2/blame.h',
        'deps/libgit2/src/libgit2/blame_git.c',
        'deps/libgit2/src/libgit2/blame_git.h',
        'deps/libgit2/src/libgit2/blob.c',
        'deps/libgit2/src/libgit2/blob.h',
        'deps/libgit2/src/libgit2/branch.c',
        'deps/libgit2/src/libgit2/branch.h',
        'deps/libgit2/src/libgit2/buf.c',
        'deps/libgit2/src/libgit2/buf.h',
        'deps/libgit2/src/libgit2/cache.c',
        'deps/libgit2/src/libgit2/cache.h',
        'deps/libgit2/src/libgit2/checkout.c',
        'deps/libgit2/src/libgit2/checkout.h',
        'deps/libgit2/src/libgit2/cherrypick.c',
        'deps/libgit2/src/libgit2/clone.c',
        'deps/libgit2/src/libgit2/clone.h',
        'deps/libgit2/src/libgit2/commit.c',
