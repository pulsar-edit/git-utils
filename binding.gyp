              'NEWLINE="LF"',
              'NO_RECURSE=1',
              'POSIX_MALLOC_THRESHOLD=10',
              'BSR_ANYCRLF=0',
              'MAX_NAME_SIZE=32',
              'MAX_NAME_COUNT=10000',
            ],
            'include_dirs': [],
            'direct_dependent_settings': {
              'include_dirs': [
                'deps/libgit2/deps/pcre',
              ],
            },
          },
      ]
    }]
  ]
